# SO360 V.2 Frontend Environment Variables Template
# Copy this file to .env and fill in the values

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Get these from: https://app.supabase.com → Your Project → Settings → API

# Supabase Project URL
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Supabase Anonymous Key (Public key - safe to use in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================
# API ENDPOINTS
# ==============================================
# Backend API base URLs - update based on environment

# Core Backend API (IAM, Tenancy, Governance)
VITE_SO360_CORE_API=http://localhost:3000
# Dev: http://[DEV_SERVER_IP]:3000
# Staging: http://[STAGING_SERVER_IP]:3000
# Production: https://api.skyoffice360.com

# CRM Backend API
VITE_CRM_API=http://localhost:3006
# Dev: http://[DEV_SERVER_IP]:3006
# Staging: http://[STAGING_SERVER_IP]:3006

# Inventory Backend API
VITE_INVENTORY_API=http://localhost:3006
# Dev: http://[DEV_SERVER_IP]:3006
# Staging: http://[STAGING_SERVER_IP]:3006

# Accounting Backend API
VITE_ACCOUNTING_API=http://localhost:3008
# Dev: http://[DEV_SERVER_IP]:3008
# Staging: http://[STAGING_SERVER_IP]:3008

# Projects Backend API
VITE_PROJECTS_API=http://localhost:3010
# Dev: http://[DEV_SERVER_IP]:3010
# Staging: http://[STAGING_SERVER_IP]:3010

# Timesheet Backend API
VITE_TIMESHEET_API=http://localhost:3012
# Dev: http://[DEV_SERVER_IP]:3012
# Staging: http://[STAGING_SERVER_IP]:3012

# People Connect Backend API
VITE_PEOPLE_API=http://localhost:3013
# Dev: http://[DEV_SERVER_IP]:3013
# Staging: http://[STAGING_SERVER_IP]:3013

# DailyStore Backend API
VITE_DAILYSTORE_API=http://localhost:3014
# Dev: http://[DEV_SERVER_IP]:3014
# Staging: http://[STAGING_SERVER_IP]:3014

# ==============================================
# NOTES
# ==============================================
# 1. NEVER commit .env files to git
# 2. Each environment (local, dev, staging, prod) needs its own .env file
# 3. Update API URLs when deploying to different environments
# 4. VITE_ prefix is required for Vite to expose variables to browser
# 5. Changes to .env require restarting the dev server
